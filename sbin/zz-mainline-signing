#!/usr/bin/env bash

# requires deb packages: binutils zstd tar curl diffutils openssl sbsigntool
# sudo apt install binutils zstd tar curl diffutils openssl sbsigntool
# optional: gnupg (verifies the CHECKSUMS signature when a deb is downloaded)
# inspired by @maxried https://gist.github.com/maxried/796d1f3101b3a03ca153fa09d3af8a11

set -e

KERNEL_IMAGE=$2
MOK_CERT_NAME="MOK-Kernel"
MOK_DIRECTORY="/var/lib/shim-signed/mok"

if [ $# -ne 2 ] ; then
    echo "Wrong count of command line arguments. This is not meant to be called directly." >&2
    exit 1
fi

if [ ! -x "$(command -v sbsign)" ]; then
    echo "sbsign not executable. Bailing." >&2
    exit 1
fi

echo "
########
## Secure Boot Mainline Kernel Signature using MOK
"

SIGN_TEMP="$(mktemp -d)"
trap 'if [ -d "$SIGN_TEMP/gnupg" ]; then gpgconf --homedir "$SIGN_TEMP/gnupg" --kill all 2>/dev/null || true; fi; rm -rf -- "$SIGN_TEMP"' EXIT

if grep -q 'vmlinuz\-.*\-\([0-9]\{6\}\)\(rc[0-9]*\)\?\-generic' <<< "$KERNEL_IMAGE"; then
    echo "${KERNEL_IMAGE} is a generic kernel image to consider signing"
    KERNEL_VERSION=$(sed -e 's/^.*vmlinuz-//g' -e 's/-generic//g' <<< "$KERNEL_IMAGE")
else
    echo "${KERNEL_IMAGE} is an official signed image or is not a generic kernel image, not auto-signing for safety" >&2
    exit 0
fi

echo "Checking if kernel image is already signed"
if grep -q "signature 1" <<< "$(sbverify --list "$KERNEL_IMAGE" 2>&1)"; then
    echo "${KERNEL_IMAGE} is already signed, aborting signing script" >&2
    sbverify --list "$KERNEL_IMAGE"
    echo "Note: If this fails to boot, it may be because your system does not trust this MOK"
    exit 0
fi

KERNEL_MAIN_VERSION=v$(sed -e 's/-.*$//' -e 's/\.0$//' <<< "$KERNEL_VERSION")
ARCH=$(dpkg --print-architecture)
KERNEL_RC_VERSION=""
if grep -q "rc" <<< "$KERNEL_VERSION"; then
  KERNEL_RC_VERSION="$(sed -e 's/.*\(\-\)\([0-9]\{6\}\)\(rc*\)/\1\3/' <<< "$KERNEL_VERSION")"
fi

MAINLINE_URL="https://kernel.ubuntu.com/mainline/${KERNEL_MAIN_VERSION}${KERNEL_RC_VERSION}/${ARCH}"
CURL_OPTS=(-fSs --connect-timeout 15 --max-time 300)
# Kernel PPA <kernel-ppa@canonical.com>, signs the mainline CHECKSUMS files
KERNEL_PPA_KEY="60AA7B6F30434AE68E569963E50C6A0917C622B0"

echo "Downloading CHECKSUMS from Ubuntu mainline PPA..."
if ! curl "${CURL_OPTS[@]}" "$MAINLINE_URL/CHECKSUMS" -o "$SIGN_TEMP/CHECKSUMS"; then
    echo "Error: Failed to download CHECKSUMS file from Ubuntu mainline PPA." >&2
    exit 1
fi

echo "Verifying CHECKSUMS signature"
if command -v gpg &>/dev/null \
   && curl "${CURL_OPTS[@]}" "$MAINLINE_URL/CHECKSUMS.gpg" -o "$SIGN_TEMP/CHECKSUMS.gpg"; then
    export GNUPGHOME="$SIGN_TEMP/gnupg"
    mkdir -p -m 700 "$GNUPGHOME"
    if gpg -q --batch --keyserver hkps://keyserver.ubuntu.com --recv-keys "$KERNEL_PPA_KEY" 2> /dev/null; then
        if gpg --batch --status-fd 1 --verify "$SIGN_TEMP/CHECKSUMS.gpg" "$SIGN_TEMP/CHECKSUMS" 2> /dev/null | grep -q "VALIDSIG $KERNEL_PPA_KEY"; then
            echo "CHECKSUMS signature verified against Kernel PPA key"
        else
            echo "Error: CHECKSUMS signature verification failed, aborting sign" >&2
            exit 1
        fi
    else
        echo "Warning: could not fetch Kernel PPA key from keyserver, skipping CHECKSUMS signature verification" >&2
    fi
    unset GNUPGHOME
else
    echo "Warning: gpg or CHECKSUMS.gpg unavailable, skipping CHECKSUMS signature verification" >&2
fi

KERNEL_IMG_DEB_NAME=$(sed -n "s/.*\(linux-image-.*${KERNEL_VERSION}.*\.deb\)/\1/p" "$SIGN_TEMP/CHECKSUMS" | grep -v "dbgsym" | head -n 1)
if [ -z "$KERNEL_IMG_DEB_NAME" ]; then
    echo "Error: Could not find kernel image deb package in CHECKSUMS file." >&2
    exit 1
fi

KERNEL_IMG_DEB_SHA256=$(sed '1,/^.*ha256:$/d' "$SIGN_TEMP/CHECKSUMS" | grep -F -- "$KERNEL_IMG_DEB_NAME" || true)
if [ -z "$KERNEL_IMG_DEB_SHA256" ]; then
    echo "Error: Could not find sha256 checksum for $KERNEL_IMG_DEB_NAME in CHECKSUMS file." >&2
    exit 1
fi

echo "Finding matching Ubuntu mainline kernels locally"
KERNEL_IMG_DEB=""
cd /
if command -v fdfind &>/dev/null; then
    KERNEL_IMG_DEB=$(fdfind -u --glob "$KERNEL_IMG_DEB_NAME" /home /root 2> /dev/null | head -n 1)
else
    KERNEL_IMG_DEB=$(find /home /root -name "$KERNEL_IMG_DEB_NAME" 2> /dev/null | head -n 1)
fi

if [ -n "$KERNEL_IMG_DEB" ] && [ -f "$KERNEL_IMG_DEB" ]; then
    echo "Found matching local deb file: $KERNEL_IMG_DEB"
    cd "$(dirname "$KERNEL_IMG_DEB")"
    if sha256sum -c <<< "$KERNEL_IMG_DEB_SHA256"; then
        echo "Successfully sha256 verified local deb package"
    else
        echo "Warning: local deb file failed sha256 verification, falling back to download" >&2
        KERNEL_IMG_DEB=""
    fi
fi

if [ -z "$KERNEL_IMG_DEB" ]; then
    echo "Downloading $KERNEL_IMG_DEB_NAME from mainline PPA..."
    KERNEL_IMG_DEB="$SIGN_TEMP/$KERNEL_IMG_DEB_NAME"
    if ! curl "${CURL_OPTS[@]}" "$MAINLINE_URL/$KERNEL_IMG_DEB_NAME" -o "$KERNEL_IMG_DEB"; then
        echo "Error: Failed to download deb package from Ubuntu mainline PPA." >&2
        exit 1
    fi
    cd "$SIGN_TEMP"
    if sha256sum -c <<< "$KERNEL_IMG_DEB_SHA256"; then
        echo "Successfully sha256 verified downloaded deb package"
    else
        echo "Error: downloaded deb package failed sha256 verification, aborting sign" >&2
        exit 1
    fi
fi

echo "Using deb: $KERNEL_IMG_DEB, Kernel image: $KERNEL_IMAGE, Sign temp: $SIGN_TEMP"

echo "Verify image being signed comes from mainline deb package"
KERNEL_IMG_DEB_CONTENTS="$(ar t "$KERNEL_IMG_DEB")"

if grep -q "data.tar.zst" <<< "$KERNEL_IMG_DEB_CONTENTS"; then
    ar p "$KERNEL_IMG_DEB" "data.tar.zst" | tar -I zstd -xOf - ".$KERNEL_IMAGE" > "$SIGN_TEMP/$(sed 's:.*/::' <<< "$KERNEL_IMAGE")"
elif grep -q "data.tar.xz" <<< "$KERNEL_IMG_DEB_CONTENTS"; then
    ar p "$KERNEL_IMG_DEB" "data.tar.xz" | tar -JxOf - ".$KERNEL_IMAGE" > "$SIGN_TEMP/$(sed 's:.*/::' <<< "$KERNEL_IMAGE")"
elif grep -q "data.tar" <<< "$KERNEL_IMG_DEB_CONTENTS"; then
    ar p "$KERNEL_IMG_DEB" "data.tar" | tar -xOf - ".$KERNEL_IMAGE" > "$SIGN_TEMP/$(sed 's:.*/::' <<< "$KERNEL_IMAGE")"
else
    echo "Could not find kernel image in reference DEB file" >&2
    exit 0
fi


if cmp "$KERNEL_IMAGE" "$SIGN_TEMP/$(sed 's:.*/::' <<< "$KERNEL_IMAGE")"; then
    echo "Validated $KERNEL_IMAGE is present in $(sed 's:.*/::' <<< "$KERNEL_IMG_DEB")"
else
    echo "$KERNEL_IMAGE does not match image in $(sed 's:.*/::' <<< "$KERNEL_IMG_DEB")" >&2
    exit 0
fi

if [ ! -r "$MOK_DIRECTORY/$MOK_CERT_NAME.der" ] ; then
    echo "$MOK_DIRECTORY/$MOK_CERT_NAME.der is not readable." >&2
    exit 1
fi

if [ ! -r "$MOK_DIRECTORY/$MOK_CERT_NAME.priv" ] ; then
    echo "$MOK_DIRECTORY/$MOK_CERT_NAME.priv is not readable." >&2
    exit 1
fi

if [ ! -w "$KERNEL_IMAGE" ] ; then
	echo "Kernel image $KERNEL_IMAGE is not writable." >&2
	exit 1
fi

if [ ! -r "$MOK_DIRECTORY/$MOK_CERT_NAME.pem" ] ; then
	echo "$MOK_CERT_NAME.pem missing. Generating from $MOK_CERT_NAME.der."
    if [ ! -x "$(command -v openssl)" ]; then
		echo "openssl could not be found." >&2
		exit 1
	fi

	openssl x509 -in "$MOK_DIRECTORY/$MOK_CERT_NAME.der" -inform DER -outform PEM -out "$MOK_DIRECTORY/$MOK_CERT_NAME.pem" || { echo "Conversion failed. Bailing." >&2; exit 1 ; }
fi

echo "Signing $KERNEL_IMAGE..."
sbsign --key "$MOK_DIRECTORY/$MOK_CERT_NAME.priv" --cert "$MOK_DIRECTORY/$MOK_CERT_NAME.pem" --output "$KERNEL_IMAGE" "$KERNEL_IMAGE"


if grep -q "signature 1" <<< "$(sbverify --list "$KERNEL_IMAGE" 2>&1)"; then # adding a new line at the end to show clearly show the end of script
    sbverify --list "$KERNEL_IMAGE"
    echo "Successfully signed $KERNEL_IMAGE
    "
else
    echo "Failed to signed $KERNEL_IMAGE
    " >&2
    exit 1
fi

